# Copy to .env and fill in, then load it into your shell before starting the agent
# (e.g. `set -a; source .env; set +a`). The real .env is gitignored.
# Cursor reads these from the environment to expand ${...} in .cursor/mcp.json.

# GitHub Personal Access Token for the GitHub MCP server (fine-grained or classic).
# Give it only the scopes you need (e.g. repo, read:org).
GITHUB_TOKEN=ghp_replace_with_your_token
