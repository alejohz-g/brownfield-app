# Copy to .env and fill in, then load it into your shell before starting the agent
# (e.g. `set -a; source .env; set +a`). The real .env is gitignored.
# Claude Code reads these from the environment to expand ${...} in .mcp.json.

# MongoDB running in your Docker container.
# The MongoDB MCP server runs in its own container, so use host.docker.internal
# (not localhost) to reach a MongoDB published on your host with -p 27017:27017.
# Add user:password@ and a db name if your container requires auth.
MDB_MCP_CONNECTION_STRING=mongodb://host.docker.internal:27017/

# GitHub Personal Access Token for the GitHub MCP server (fine-grained or classic).
# Give it only the scopes you need (e.g. repo, read:org).
GITHUB_TOKEN=ghp_replace_with_your_token
